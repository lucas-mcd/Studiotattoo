      </section>

      <!-- SEÇÃO FINELINE -->
      <section class="style-section" data-style="Fineline">
        <p class="tag">TATTOO // ART // IDENTITY</p>
        <h1>Fineline</h1>
        <p class="section-intro">Linhas delicadas, elegância visual e precisão estética para quem curte sutileza com identidade forte.</p>
        
        <div class="gallery">
          <div class="gallery-item">
            <img src="/images/fineline/image.webp" alt="Fineline Tattoo 1" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/fineline/image copy.webp" alt="Fineline Tattoo 2" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/fineline/image copy 2.webp" alt="Fineline Tattoo 3" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/fineline/image copy 3.webp" alt="Fineline Tattoo 4" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/fineline/image copy 4.webp" alt="Fineline Tattoo 5" loading="lazy" decoding="async" />
          </div>
        </div>
      </section>

      <!-- SEÇÃO MINIMALISTA -->
      <section class="style-section" data-style="Minimalista">
        <p class="tag">TATTOO // ART // IDENTITY</p>
        <h1>Minimalista</h1>
        <p class="section-intro">Poucos elementos, muito significado. Um estilo limpo, moderno e poderoso na simplicidade.</p>
        
        <div class="gallery">
          <div class="gallery-item">
            <img src="/images/minimalista/image.webp" alt="Minimalista Tattoo 1" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/minimalista/image copy.webp" alt="Minimalista Tattoo 2" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/minimalista/image copy 2.webp" alt="Minimalista Tattoo 3" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/minimalista/image copy 3.webp" alt="Minimalista Tattoo 4" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/minimalista/image copy 4.webp" alt="Minimalista Tattoo 5" loading="lazy" decoding="async" />
          </div>
        </div>
      </section>

      <!-- SEÇÃO ORIENTAL -->
      <section class="style-section" data-style="Oriental">
        <p class="tag">TATTOO // ART // IDENTITY</p>
        <h1>Oriental</h1>
        <p class="section-intro">Arte grandiosa, simbologia profunda e composições marcantes inspiradas na tradição oriental clássica.</p>
        
        <div class="gallery">
          <div class="gallery-item">
            <img src="/images/oriental/image.webp" alt="Oriental Tattoo 1" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/oriental/image copy.webp" alt="Oriental Tattoo 2" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/oriental/image copy 2.webp" alt="Oriental Tattoo 3" loading="lazy" decoding="async" />
          </div>

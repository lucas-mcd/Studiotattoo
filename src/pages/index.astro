    </main>

    <div id="modal-img" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.9);z-index:9999;align-items:center;justify-content:center;">
      <button id="prev-img" style="position:absolute;left:30px;top:50%;transform:translateY(-50%);background:none;border:none;color:#00f7ff;font-size:40px;cursor:pointer;transition:all 0.2s ease;padding:10px;opacity:0.7;" onmouseover="this.style.opacity='1';this.style.transform='translateY(-50%) scale(1.2)';" onmouseout="this.style.opacity='0.7';this.style.transform='translateY(-50%) scale(1)';">❮</button>
      <img id="modal-img-src" style="max-width:90%;max-height:90%;">
      <button id="next-img" style="position:absolute;right:30px;top:50%;transform:translateY(-50%);background:none;border:none;color:#00f7ff;font-size:40px;cursor:pointer;transition:all 0.2s ease;padding:10px;opacity:0.7;" onmouseover="this.style.opacity='1';this.style.transform='translateY(-50%) scale(1.2)';" onmouseout="this.style.opacity='0.7';this.style.transform='translateY(-50%) scale(1)';">❯</button>
      <button id="close-modal-img" style="position:absolute;top:30px;right:30px;background:none;border:none;color:#00f7ff;font-size:40px;cursor:pointer;transition:all 0.2s ease;opacity:0.7;padding:10px;" onmouseover="this.style.opacity='1';this.style.transform='scale(1.2)';" onmouseout="this.style.opacity='0.7';this.style.transform='scale(1)';">×</button>
    </div>
  </div>

  <script is:inline>
    // ===============================
    // EFEITO DO MOUSE
    // ===============================
    const mouseGlow = document.querySelector(".mouse-glow");

    window.addEventListener("mousemove", (e) => {
      mouseGlow.style.left = `${e.clientX}px`;
      mouseGlow.style.top = `${e.clientY}px`;
    });

    // ===============================
    // INTRO ANIMADA
    // ===============================
    const intro = document.getElementById("intro");
    const lines = document.querySelectorAll(".line");

    function animateIntroLines() {
      lines.forEach((line, index) => {
        setTimeout(() => {
          line.classList.add("show");
        }, index * 700);
      });

      setTimeout(() => {
        intro.classList.add("hide");
        document.getElementById("about-menu").classList.add("active");
      }, 4200);
    }

    // Iniciar quando DOM estiver pronto
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        setTimeout(animateIntroLines, 800);
      });
    } else {
      setTimeout(animateIntroLines, 800);
    }


    // ===============================
    // MENU INTERATIVO (Navegação de Seções)
    // ===============================
    const menuItems = document.querySelectorAll(".menu-item");
    const sections = document.querySelectorAll(".style-section");

    menuItems.forEach(item => {
      item.addEventListener("click", () => {
        const selectedStyle = item.dataset.style;

        // Remover classe active de todos os itens e seções
        menuItems.forEach(btn => btn.classList.remove("active"));
        sections.forEach(section => section.classList.remove("active"));

        // Adicionar classe active no item clicado
        item.classList.add("active");

        // Encontrar e mostrar a seção correspondente
        const targetSection = document.querySelector(`.style-section[data-style="${selectedStyle}"]`);
        if (targetSection) {
          targetSection.classList.add("active");

          // Scroll suave até a seção
          const content = document.querySelector(".content");
          const sectionTop = targetSection.offsetTop - 100;
          content.scrollTo({
            top: sectionTop,
            behavior: "smooth"
          });
        }
      });
    });

    // ===============================
    // MENU SOBRE MIM
    // ===============================
    const aboutMenu = document.getElementById("about-menu");
    const closeAbout = document.getElementById("close-about");
    const proceedAbout = document.getElementById("proceed-about");
    const mainSiteDiv = document.getElementById("main-site");

    function showMainSite() {
      aboutMenu.classList.remove("active");
      mouseGlow.style.zIndex = "2"; // voltar ao z-index original
      mainSiteDiv.classList.remove("hidden");
      
      // Ativar o primeiro menu "Old School"
      const firstStyleBtn = document.querySelector('.menu-item[data-style="Old School"]');
      if (firstStyleBtn) {
        firstStyleBtn.click();
      }
      
      // Remover active do botão "Sobre Mim"
      sobreMimBtn.classList.remove("active");
    }

    proceedAbout.addEventListener("click", showMainSite);
    closeAbout.addEventListener("click", showMainSite);

    // Botão "Sobre Mim" no menu para reabrir o modal
    const sobreMimBtn = document.getElementById("sobre-mim-btn");
    sobreMimBtn.addEventListener("click", () => {
      aboutMenu.classList.add("active");
      mouseGlow.style.zIndex = "9";
      // Remove active dos menu items
      menuItems.forEach(item => item.classList.remove("active"));
      sobreMimBtn.classList.add("active");
    });

    // Aumentar z-index do mouse-glow quando modal está ativo
    const observer = new MutationObserver(() => {
      if (aboutMenu.classList.contains("active")) {
        mouseGlow.style.zIndex = "9"; // acima do modal
      }
    });
    observer.observe(aboutMenu, { attributes: true, attributeFilter: ["class"] });

    // ===============================
    // MENU CONTATO
    // ===============================
    const contactMenu = document.getElementById("contact-menu");
    const contactBtn = document.getElementById("contact-btn");
    const closeContact = document.getElementById("close-contact");

    function openContactMenu() {
      contactMenu.classList.add("active");
      mouseGlow.style.zIndex = "9";
    }

    function closeContactMenu() {
      contactMenu.classList.remove("active");
      mouseGlow.style.zIndex = "2";
    }

    contactBtn.addEventListener("click", openContactMenu);
    closeContact.addEventListener("click", closeContactMenu);

    // Fechar modal ao clicar fora
    contactMenu.addEventListener("click", (e) => {
      if (e.target === contactMenu) {
        closeContactMenu();
      }
    });

    // Aumentar z-index do mouse-glow quando contact modal está ativo
    const contactObserver = new MutationObserver(() => {
      if (contactMenu.classList.contains("active")) {
        mouseGlow.style.zIndex = "9";
      }
    });
    contactObserver.observe(contactMenu, { attributes: true, attributeFilter: ["class"] });
  </script>

  <!-- BOTÃO INSTAGRAM -->
  <a href="https://www.instagram.com/pretto_tatto0/" target="_blank" rel="noopener noreferrer" class="instagram-btn" aria-label="Instagram">
    <button class="Btn">
      <span class="svgContainer">
        <svg fill="white" class="svgIcon" viewBox="0 0 448 512" width="24" height="24" xmlns="http://www.w3.org/2000/svg">
          <path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"></path>
        </svg>
      </span>
      <span class="BG"></span>
    </button>
  </a>

  <!-- BOTÃO WHATSAPP -->
  <a href="https://wa.me/5500000000000" target="_blank" rel="noopener noreferrer" class="whatsapp-btn" aria-label="WhatsApp">
    <button class="Btn">

            <img src="/images/oriental/image copy 3.webp" alt="Oriental Tattoo 4" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/oriental/image copy 4.webp" alt="Oriental Tattoo 5" loading="lazy" decoding="async" />

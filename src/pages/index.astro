---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Studio Tattoo Cyber Tribal">
  <!-- INTRO -->
  <section id="intro" class="intro">
    <img src="/images/preto.png" alt="Logo Tattoo" class="intro-logo" />

    <div class="intro-text">
      <h1 class="line">Arte marcada na pele.</h1>
      <h1 class="line">Identidade, força e presença.</h1>
      <h1 class="line">Bem-vindo ao Studio Tattoo.</h1>
    </div>
  </section>

  <!-- MENU SOBRE MIM (Overlay) -->
  <div id="about-menu" class="about-menu">
    <div class="about-menu-content">
      <button class="close-about" id="close-about">×</button>
      
      <!-- PHOTO -->
      <img src="/images/perfil.webp" alt="Tatuador" class="about-photo" />
      
      <!-- TEXTO SOBRE MIM -->
      <h2>Sobre Mim</h2>
      <p class="about-intro">Sou um tatuador apaixonado pela fusão entre arte, identidade e impacto visual. Cada tatuagem que faço é uma conversa entre você e eu - sobre quem você é, o que você carrega e como você quer se expressar através da pele.</p>
      <p class="about-pitch">Meu trabalho vai além de tinta. É sobre criar marcas que fazem você se sentir mais você. Trabalho com precisão, criatividade e a certeza de que uma tatuagem bem-feita é um investimento em si mesmo.</p>
      
      <!-- CARDS DOS ESTILOS -->
      <div class="about-cards">
        <div class="about-card">
          <h3>Estilo Vivo</h3>
          <p>Design visual intenso com atmosfera futurista e brutal.</p>
        </div>

        <div class="about-card">
          <h3>Traço com Presença</h3>
          <p>Uma estética pensada para valorizar arte, pele e identidade.</p>
        </div>

        <div class="about-card">
          <h3>Experiência Imersiva</h3>
          <p>Interface interativa feita pra impressionar quem entra no site.</p>
        </div>
      </div>

      <!-- CTA -->
      <button class="cta-about" id="proceed-about">Explorar Meu Trabalho →</button>
    </div>
  </div>

  <!-- MENU CONTATO (Overlay) -->
  <div id="contact-menu" class="contact-menu">
    <div class="contact-menu-content">
      <button class="close-contact" id="close-contact">×</button>
      
      <h2>Contato</h2>
      <p class="contact-intro">Conecte-se comigo através dos canais abaixo.</p>
      
      <div class="contact-cards">
        <div class="contact-card">
          <svg class="card-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          <h3>Endereço</h3>
          <p>Rua da Criatividade, 456<br />Studio Cyber Tribal<br />São Paulo - SP, 01234-567</p>
        </div>
        
        <div class="contact-card">
          <svg class="card-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
          <h3>Email</h3>
          <p><a href="mailto:hello@cybertattoo.com">hello@cybertattoo.com</a></p>
        </div>
        
        <div class="contact-card">
          <svg class="card-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <circle cx="17.5" cy="6.5" r="1.5"></circle>
          </svg>
          <h3>Instagram</h3>
          <p><a href="https://www.instagram.com/pretto_tatto0/" target="_blank">@cybertattoo</a></p>
        </div>
        
        <div class="contact-card">
          <svg class="card-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
          </svg>
          <h3>WhatsApp</h3>
          <p><a href="https://wa.me/5500000000000" target="_blank">+55 (11) 98765-4321</a></p>
        </div>
      </div>
    </div>
  </div>

  <!-- SITE PRINCIPAL -->
  <div id="main-site" class="main-site hidden">
    <!-- OVERLAY PARA MOBILE -->
    <div class="mobile-overlay" id="mobile-overlay"></div>

    <!-- BOTÃO MENU HAMBÚRGUER (Mobile) -->
    <button class="hamburger-menu" id="hamburger-menu">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <!-- BOTÃO CONTATO (Top Right) -->
    <div class="contact-button-container">
      <button class="contact-btn" id="contact-btn">Contato</button>
    </div>

    <!-- MENU LATERAL -->
    <aside class="sidebar">
      <div class="sidebar-top">
        <h2>INK//STYLE</h2>
        <p>Cyber Tribal Studio</p>
      </div>

      <nav class="menu">
        <button class="menu-item sobre-mim-btn" id="sobre-mim-btn">Sobre Mim</button>
        <button class="menu-item active" data-style="Old School">Old School</button>
        <button class="menu-item" data-style="Realismo">Realismo</button>
        <button class="menu-item" data-style="Blackwork">Blackwork</button>
        <button class="menu-item" data-style="Fineline">Fineline</button>
        <button class="menu-item" data-style="Minimalista">Minimalista</button>
        <button class="menu-item" data-style="Oriental">Oriental</button>
        <button class="menu-item" data-style="Tribal">Tribal</button>
      </nav>
    </aside>

    <!-- CONTEÚDO -->
    <main class="content">
      <div class="content-glow"></div>

      <!-- SEÇÃO OLD SCHOOL -->
      <section class="style-section active" data-style="Old School">
        <p class="tag">TATTOO // ART // IDENTITY</p>
        <h1>Old School</h1>
        <p class="section-intro">Traços clássicos, cores marcantes e personalidade forte. O Old School carrega tradição, atitude e símbolos eternos da tatuagem.</p>
        
        <div class="gallery">
          <div class="gallery-item">
            <img src="/images/oldschool/image.webp" alt="Old School Tattoo 1" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/oldschool/image copy.webp" alt="Old School Tattoo 2" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/oldschool/image copy 2.webp" alt="Old School Tattoo 3" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/oldschool/image copy 3.webp" alt="Old School Tattoo 4" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/oldschool/image copy 4.webp" alt="Old School Tattoo 5" loading="lazy" decoding="async" />
          </div>
        </div>
      </section>

      <!-- SEÇÃO REALISMO -->
      <section class="style-section" data-style="Realismo">
        <p class="tag">TATTOO // ART // IDENTITY</p>
        <h1>Realismo</h1>
        <p class="section-intro">Detalhes impressionantes, profundidade visual e tatuagens que parecem ganhar vida na pele com impacto e técnica refinada.</p>
        
        <div class="gallery">
          <div class="gallery-item">
            <img src="/images/realismo/image.webp" alt="Realismo Tattoo 1" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/realismo/image copy.webp" alt="Realismo Tattoo 2" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/realismo/image copy 2.webp" alt="Realismo Tattoo 3" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/realismo/image copy 3.webp" alt="Realismo Tattoo 4" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/realismo/image copy 4.webp" alt="Realismo Tattoo 5" loading="lazy" decoding="async" />
          </div>
        </div>
      </section>

      <!-- SEÇÃO BLACKWORK -->
      <section class="style-section" data-style="Blackwork">
        <p class="tag">TATTOO // ART // IDENTITY</p>
        <h1>Blackwork</h1>
        <p class="section-intro">Preto intenso, contraste brutal e composições pesadas que transformam o corpo em uma obra de presença absoluta.</p>
        
        <div class="gallery">
          <div class="gallery-item">

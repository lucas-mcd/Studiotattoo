      <!-- SEÇÃO TRIBAL -->
      <section class="style-section" data-style="Tribal">
        <p class="tag">TATTOO // ART // IDENTITY</p>
        <h1>Tribal</h1>
        <p class="section-intro">Força ancestral, formas orgânicas e impacto visual bruto. O tribal carrega raiz, identidade e poder.</p>
        
        <div class="gallery">
          <div class="gallery-item">
            <img src="/images/tribal/image.webp" alt="Tribal Tattoo 1" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/tribal/image copy.webp" alt="Tribal Tattoo 2" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/tribal/image copy 2.webp" alt="Tribal Tattoo 3" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/tribal/image copy 3.webp" alt="Tribal Tattoo 4" loading="lazy" decoding="async" />
          </div>

            <img src="/images/Blackwork/image copy 2.webp" alt="Blackwork Tattoo 3" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
            <img src="/images/Blackwork/image copy 3.webp" alt="Blackwork Tattoo 4" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item">
